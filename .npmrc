# pnpm configuration for monorepo
# Дозволяє залежностям бути доступними на рівні кореня (важливо для Vite + React)
shamefully-hoist=true

# Не блокувати встановлення при помилках peer dependencies
strict-peer-dependencies=false

# Автоматично встановлювати peer dependencies
auto-install-peers=true
